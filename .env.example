# ==========================================
# ENV FILE EXAMPLE FOR PRODUCTION DEPLOYMENT
# ==========================================
# Copy this file to '.env' in your server before running docker-compose up -d

# Backend API Port mapping for the host
PORT=5000

# Security Secret (Change this!)
JWT_SECRET=super_secret_wifi_key_production_123

# Database configuration (These match docker-compose.yml postgres service)
POSTGRES_USER=wifian
POSTGRES_PASSWORD=wifian123
POSTGRES_DB=wifianID
DATABASE_URL=postgresql://wifian:wifian123@postgres-db:5432/wifianID?schema=public

# Redis configuration (Matches docker-compose.yml redis service)
REDIS_URL=redis://redis-server:6379
